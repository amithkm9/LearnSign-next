# ============================================
# LearnSign (Next.js) — local environment
# Copy to .env.local and fill in real values.
# ============================================

# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string (Project Settings → Database → Connection string).
# Use the "Transaction" pooler URL (port 6543) for the app; add ?sslmode=require.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?sslmode=require

# --- Python AI service (tutor chat, voice, parent-report insights, sign recognition) ---
# The OpenAI key lives in ai-service/.env, not here.
AI_SERVICE_URL=http://localhost:8100
