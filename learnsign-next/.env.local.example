# ============================================
# LearnSign (Next.js) — local environment
# Copy to .env.local and fill in real values.
# ============================================

# Public site URL — used to build password-reset / email-confirmation links.
# In prod set this to your deployed domain (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string (Project Settings → Database → Connection string).
# Use the "Transaction" pooler URL (port 6543) for the app; add ?sslmode=require.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?sslmode=require

# --- Python AI service (tutor chat, voice, parent-report insights, sign recognition) ---
# In prod, point this at the deployed service (e.g. your Hugging Face Space URL).
AI_SERVICE_URL=http://localhost:8100
# Shared secret the gateway sends to the AI service (must match ai-service's value).
# Generate one: `openssl rand -hex 32`. Leave empty for local dev.
INTERNAL_API_TOKEN=

# --- Media (sign/course videos) ---
# Base URL where the ~340 MB of videos are hosted (e.g. Supabase Storage public bucket).
# Leave empty to serve from /public locally.
# e.g. https://YOUR-PROJECT.supabase.co/storage/v1/object/public/media
NEXT_PUBLIC_MEDIA_BASE_URL=
